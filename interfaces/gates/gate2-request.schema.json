{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/gate-2-request.schema.json",
  "title": "Gate 2 Request",
  "type": "object",
  "required": [
    "gate2_thread_id",
    "workflow_id",
    "originator_role",
    "reason",
    "created_at"
  ],
  "properties": {
    "gate2_thread_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": "string"
    },
    "originator_role": {
      "type": "string",
      "enum": [
        "A1",
        "A2",
        "A3"
      ]
    },
    "originator_instance_id": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "error_code": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "error",
        "critical"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_resolution": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
