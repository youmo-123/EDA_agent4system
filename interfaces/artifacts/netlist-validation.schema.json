{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/netlist-validation.schema.json",
  "title": "Netlist Validation",
  "type": "object",
  "required": [
    "created_at",
    "status",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "valid",
        "invalid"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cell_count": {
      "type": "integer"
    }
  },
  "additionalProperties": true
}
