{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/equivalence-result.schema.json",
  "title": "Equivalence Result",
  "type": "object",
  "required": [
    "created_at",
    "status",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "equivalent",
        "not_equivalent",
        "inconclusive",
        "unsupported"
      ]
    },
    "method": {
      "type": "string"
    },
    "evidence_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
