{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/search-experiment-manifest.schema.json",
  "title": "Search Experiment Manifest",
  "type": "object",
  "required": [
    "created_at",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "experiment_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "experiment_id": {
      "type": "string"
    },
    "search_mode": {
      "type": "string",
      "enum": [
        "catalog",
        "evolutionary",
        "parallel_catalog"
      ]
    },
    "seed": {
      "type": [
        "integer",
        "null"
      ]
    },
    "population_size": {
      "type": [
        "integer",
        "null"
      ]
    },
    "generations": {
      "type": [
        "integer",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
