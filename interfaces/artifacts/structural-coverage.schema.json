{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/structural-coverage.schema.json",
  "title": "Structural Coverage",
  "type": "object",
  "required": [
    "created_at",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "metrics",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metrics": {
      "type": "object"
    },
    "raw_report_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "backend": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
