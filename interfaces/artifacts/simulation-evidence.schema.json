{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/simulation-evidence.schema.json",
  "title": "Simulation Evidence",
  "type": "object",
  "required": [
    "simulation_ref",
    "compile_ref",
    "created_at",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "compile_ref": {
      "type": "string"
    },
    "simulation_ref": {
      "type": "string"
    },
    "pass_count": {
      "type": "integer",
      "minimum": 0
    },
    "fail_count": {
      "type": "integer",
      "minimum": 0
    },
    "logs_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
