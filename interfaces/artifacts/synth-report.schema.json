{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/synth-report.schema.json",
  "title": "Synth Report",
  "type": "object",
  "required": [
    "candidate_id",
    "created_at",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "candidate_id": {
      "type": "string"
    },
    "backend_profile_id": {
      "type": "string"
    },
    "strategy_id": {
      "type": "string"
    },
    "netlist_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "area": {
      "type": [
        "number",
        "null"
      ]
    },
    "arrival": {
      "type": [
        "number",
        "null"
      ]
    },
    "slack": {
      "type": [
        "number",
        "null"
      ]
    },
    "runtime_s": {
      "type": [
        "number",
        "null"
      ]
    },
    "tool_versions": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
