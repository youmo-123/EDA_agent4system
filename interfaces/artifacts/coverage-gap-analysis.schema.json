{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/coverage-gap-analysis.schema.json",
  "title": "Coverage Gap Analysis",
  "type": "object",
  "required": [
    "coverage_result_ref",
    "created_at",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "coverage_result_ref": {
      "type": "string"
    },
    "reachable_gaps": {
      "type": "array"
    },
    "suspected_unreachable": {
      "type": "array"
    },
    "observability_gaps": {
      "type": "array"
    },
    "priority_targets": {
      "type": "array"
    },
    "selected_generation_strategy": {
      "type": "string",
      "enum": [
        "directed",
        "constraint-solver",
        "mutation",
        "random-reweight",
        "request-info"
      ]
    },
    "next_test_plan": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
