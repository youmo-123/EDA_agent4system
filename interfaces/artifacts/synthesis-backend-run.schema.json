{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/synthesis-backend-run.schema.json",
  "title": "Synthesis Backend Run",
  "type": "object",
  "required": [
    "created_at",
    "run_id",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "type": "string"
    },
    "backend": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exit_code": {
      "type": "integer"
    },
    "stdout_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "stderr_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
