{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/diagnostic-coverage-report.schema.json",
  "title": "Diagnostic Coverage Report",
  "type": "object",
  "required": [
    "source",
    "created_at",
    "note",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "a1_simulator"
      ]
    },
    "counters": {
      "type": "object"
    },
    "note": {
      "type": "string",
      "description": "明示：不是 A2 正式覆盖率"
    }
  },
  "additionalProperties": true
}
