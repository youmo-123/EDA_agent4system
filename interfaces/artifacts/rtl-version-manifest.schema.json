{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/rtl-version-manifest.schema.json",
  "title": "Rtl Version Manifest",
  "type": "object",
  "required": [
    "rtl_version_id",
    "created_at",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "files",
    "top",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": "string"
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "top": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "constraints_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
