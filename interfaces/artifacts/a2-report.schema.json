{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/artifacts/a2-report.schema.json",
  "title": "A2 Report",
  "type": "object",
  "required": [
    "created_at",
    "run_id",
    "artifact_hash",
    "schema_version",
    "workflow_id",
    "producer_agent_instance_id"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "workflow_round_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rtl_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_agent_instance_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "artifact_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "type": "string"
    },
    "phase_status": {
      "type": "object"
    },
    "reproduce_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "backend_versions": {
      "type": "object"
    },
    "failures": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
