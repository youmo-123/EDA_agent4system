{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooragent.local/interfaces/hook-state.schema.json",
  "title": "Hook State",
  "type": "object",
  "required": [
    "entity_id",
    "state",
    "state_version"
  ],
  "properties": {
    "entity_id": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "DISABLED",
        "ARMED",
        "OBSERVING",
        "TRIGGERED",
        "ESCALATING",
        "COOLDOWN",
        "DEGRADED"
      ]
    },
    "state_version": {
      "type": "integer",
      "minimum": 0
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
