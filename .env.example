# DoorAgent 模型 Provider 与运行时环境变量（示例，不含真实密钥）
# 所有真实值必须通过环境变量或密钥系统注入，禁止 commit 真实 .env。

DOORAGENT_MODEL_PROVIDER=openai_compatible
DOORAGENT_MODEL_API_KEY=replace_me
DOORAGENT_MODEL_BASE_URL=https://example.invalid/v1
DOORAGENT_MODEL_NAME=replace_me
DOORAGENT_MODEL_TIMEOUT_S=120
DOORAGENT_MODEL_MAX_RETRIES=3

# 可选：各 Agent 覆盖全局模型名；未设置时继承 DOORAGENT_MODEL_NAME
DOORAGENT_MASTER_MODEL_NAME=
DOORAGENT_A1_MODEL_NAME=
DOORAGENT_A2_MODEL_NAME=
DOORAGENT_A3_MODEL_NAME=

# 外部 EDA 后端可执行路径（缺失时对应 Tool 返回 UNAVAILABLE）
DOORAGENT_YOSYS_BIN=yosys
DOORAGENT_ABC_BIN=abc
DOORAGENT_OPENSTA_BIN=sta
DOORAGENT_ICARUS_IVERILOG_BIN=iverilog
DOORAGENT_ICARUS_VVP_BIN=vvp
DOORAGENT_VCS_BIN=vcs
DOORAGENT_URG_BIN=urg
